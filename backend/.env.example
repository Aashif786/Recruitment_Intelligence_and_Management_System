# CALRIMS backend — copy to .env (or .env.local / .env.production)
# See README.md and CLIENT_SETUP_GUIDE.md for full setup.

# =============================================================================
# Environment
# =============================================================================
ENV=development
DEBUG=false
BACKEND_START_MODE=script

# =============================================================================
# Database (Supabase — Project Settings → Database → Connection string URI)
# =============================================================================
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# Security (required)
# =============================================================================
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
# Optional isolated candidate-interview JWT secret.
# If set, set the same value in frontend/.env.local so middleware can validate interview links.
# If omitted in development, the app uses JWT_SECRET + "_interview".
# INTERVIEW_JWT_SECRET=
# Fernet key for encrypted phone fields — generate via app or cryptography.fernet
ENCRYPTION_KEY=

# Optional: offer-letter PDF route auth (defaults to JWT_SECRET if unset)
# PDF_GENERATION_SECRET=

# =============================================================================
# Supabase Storage
# =============================================================================
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Alias used if SUPABASE_SERVICE_ROLE_KEY is set; either key name works
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Bucket names (match CLIENT_SETUP_GUIDE §2.3)
SUPABASE_BUCKET_RESUMES=resumes
SUPABASE_BUCKET_OFFERS=offer-letters
SUPABASE_BUCKET_ID_CARDS=id-cards
SUPABASE_BUCKET_ID_PHOTOS=id-photos
SUPABASE_BUCKET_VIDEOS=videos

# =============================================================================
# CORS & URLs
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000

# =============================================================================
# AI (at least one provider required in production)
# =============================================================================
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# Email — configure SMTP and/or Resend
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM=

# IMAP resume ingestion (optional)
IMAP_EMAIL=
IMAP_PASSWORD=

# =============================================================================
# Super Admin bootstrap (optional — created on first startup if set)
# =============================================================================
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FULL_NAME=Super Admin

# =============================================================================
# Redis (optional — shared idempotency across workers)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Observability & branding
# =============================================================================
# SENTRY_DSN=
COMPANY_NAME=Company

# =============================================================================
# LinkedIn job posting (optional)
# =============================================================================
# ENABLE_LINKEDIN_POSTING=false
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_ID=
