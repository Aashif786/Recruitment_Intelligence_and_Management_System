# CALRIMS frontend — copy to .env.local for local development
# Production: set at Docker build time (see docker-compose.prod.yml NEXT_PUBLIC_* args)

# Backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:10000

# Next.js Node/Edge proxy target (falls back to NEXT_PUBLIC_API_BASE_URL)
BACKEND_URL=http://127.0.0.1:10000

# JWT Secret for Edge Middleware verification (must match backend secret)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_VALUE

# Optional isolated candidate-interview JWT secret.
# If set in the backend, set the same value here so middleware can validate interview links.
# If omitted in development, the app uses JWT_SECRET + "_interview".
# INTERVIEW_JWT_SECRET=

# Optional: public site URL (if used by your deployment)
# NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
